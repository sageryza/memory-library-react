rules_version = '2';

// Journal-scan backfill only. Everything else stays locked: Cloud Functions
// use the Admin SDK (which bypasses these rules) and all image loads use
// tokened download URLs (which also bypass rules), so no existing client
// relies on Storage rules — confirmed: no web or iOS client uses the Storage
// SDK. The one new capability is letting the (anonymously) signed-in
// JournalReader app upload the user's own journal PDFs + an index file.
service firebase.storage {
  match /b/{bucket}/o {
    match /journal-scans/{path=**} {
      allow read, write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
