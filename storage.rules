rules_version = '2';

// Journal-scan backfill only. Everything else stays locked: Cloud Functions
// use the Admin SDK (which bypasses these rules) and all image loads use
// tokened download URLs (which also bypass rules), so no existing client
// relies on Storage rules — confirmed: no web or iOS client uses the Storage
// SDK. The one new capability is letting the (anonymously) signed-in
// JournalReader app upload the user's own journal PDFs + an index file.
service firebase.storage {
  match /b/{bucket}/o {
    match /journal-scans/{path=**} {
      allow read, write: if request.auth != null;
    }
    // ShouldiMakeThis.com submission photos — each signed-in user uploads into
    // their own folder. The app stores the tokened download URL in Firestore,
    // so no read rule is needed here.
    match /simt-submissions/{uid}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == uid
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    // XI shared-deck card art — only the curator uploads; the app stores the
    // tokened download URL in xi/deckExtras, so no read rule is needed.
    match /xi-deck/{fileName} {
      allow write: if request.auth != null
                   && request.auth.token.email == 'sageryza@gmail.com'
                   && request.auth.token.email_verified == true
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
