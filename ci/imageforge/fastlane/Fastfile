default_platform(:ios)

# Creates the App Store Connect app record + registers the bundle id for
# ImageForge, using the App Store Connect API key (no Mac, no Apple ID login).
# Idempotent: if the app already exists, produce detects it and moves on.
platform :ios do
  desc "Create the App Store Connect app record + bundle id (idempotent)"
  lane :ensure_app do
    # Sets Spaceship::ConnectAPI.token globally, which produce then uses — the
    # produce action itself has no api_key parameter.
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_P8"],
      is_key_content_base64: true
    )
    produce(
      app_identifier: "com.sageryza.imageforge",
      app_name: "ImageForge",
      team_id: ENV["APPLE_TEAM_ID"],
      sku: "com.sageryza.imageforge",
      language: "English",
      skip_itc: false,
      skip_devcenter: false
    )
  end
end
