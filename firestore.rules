rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Little Book of Miracles — one cloud-backup document per (anonymous) user.
    match /miracleBooks/{uid} {
      allow read, write: if isOwner(uid);
    }

    // User-specific data (existing rules)
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // ImageForge creations (sticker sheets, coloring pages, …). Written only
      // by the Cloud Function (admin SDK); the owner reads them so generations
      // survive a dropped connection / app restart and appear in a grid.
      match /creations/{creationId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // User's profile (readable by anyone for attribution, writable only by owner)
      match /profile/{profileId} {
        allow read: if true;  // Anyone can read profiles for attribution
        allow write: if isOwner(userId);
      }

      // User's memories
      match /memories/{memoryId} {
        allow read, write: if isOwner(userId);
      }

      // User's Commons — friends' memories brought in from Versus games and
      // shared boards. Owner-only, just like their own memories.
      match /commons/{memoryId} {
        allow read, write: if isOwner(userId);
      }

      // User's board state
      match /boardState/{stateId} {
        allow read, write: if isOwner(userId);
      }

      // User's saved boards
      match /boards/{boardId} {
        allow read, write: if isOwner(userId);
      }

      // User's libraries
      match /libraries/{libraryId} {
        allow read, write: if isOwner(userId);

        // Library memories
        match /memories/{memoryId} {
          allow read, write: if isOwner(userId);
        }
      }

      // User's playgrounds
      match /playgrounds/{playgroundId} {
        allow read, write: if isOwner(userId);

        // Playground messages
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }

      // User's playground memories (stored separately from playgrounds)
      match /playground-memories/{memoryId} {
        allow read, write: if isOwner(userId);
      }

      // User's chronology state
      match /chronologyState/{stateId} {
        allow read, write: if isOwner(userId);
      }

      // User's constellation state
      match /constellationState/{stateId} {
        allow read, write: if isOwner(userId);
      }

      // User's constellations (saved board configurations)
      match /constellations/{constellationId} {
        allow read, write: if isOwner(userId);
      }

      // User's preferences
      match /preferences/{prefId} {
        allow read, write: if isOwner(userId);
      }

      // User's XI settings (excluded cards, board layout, daily pair, misses)
      match /xiSettings/{stateId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Public memories — the XI "others" feed. Written ONLY by the
    // publishMemory Cloud Function (Admin SDK bypasses rules) after an AI
    // safety screen; clients read, and an owner may delete their own copy.
    match /publicMemories/{pubId} {
      allow read: if true;
      allow create, update: if false;
      allow delete: if isAuthenticated() && resource.data.byUid == request.auth.uid;
    }

    // XI moderation reports (Versus stories + public memories) — write-only
    // from clients, reviewed in the console. versusReports previously had NO
    // rule at all, so report submissions were silently denied.
    match /versusReports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if false;
    }
    match /xiReports/{reportId} {
      allow create: if isAuthenticated()
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // Shared boards - link-based sharing
    match /sharedBoards/{shareId} {
      // Anyone with the link can read
      allow read: if true;

      // Only authenticated users can create shares
      allow create: if isAuthenticated();

      // Anyone can update (collaborative editing)
      allow update: if true;

      // Only the creator can delete
      allow delete: if isAuthenticated()
                    && resource.data.sharedBy.userId == request.auth.uid;
    }

    // Public boards - accessible to everyone
    match /publicBoards/{boardId} {
      // Anyone can read public boards
      allow read: if true;

      // Anyone can create a public board (authenticated or anonymous)
      allow create: if true;

      // Only the creator can update the board metadata
      allow update: if resource.data.createdBy == request.auth.uid
                    || !isAuthenticated();

      // Only the creator can delete the board
      allow delete: if isAuthenticated()
                    && resource.data.createdBy == request.auth.uid;

      // Board memories
      match /memories/{memoryId} {
        // Anyone can read memories on public boards
        allow read: if true;

        // Anyone can add memories to public boards
        allow create, update: if true;

        // Anyone can remove memories (collective editing)
        allow delete: if true;
      }

      // Board connections
      match /connections/{connectionId} {
        // Anyone can read connections
        allow read: if true;

        // Anyone can create connections
        allow create: if true;

        // Anyone can remove connections (collective editing)
        allow delete: if true;
      }

      // Board standalone pins
      match /pins/{pinId} {
        // Anyone can read pins
        allow read: if true;

        // Anyone can create pins
        allow create: if true;

        // Anyone can remove pins (collective editing)
        allow delete: if true;
      }
    }

    // XI Versus — async multiplayer games (link-based, collaborative).
    match /versusGames/{gameId} {
      // Anyone with the link can watch / join.
      allow read: if true;
      // Signed-in users start and play games (turn order is enforced
      // client-side for v1; can be hardened with a Cloud Function later).
      allow create, update: if isAuthenticated();
      // Only the creator can delete a game.
      allow delete: if isAuthenticated()
                    && resource.data.createdBy == request.auth.uid;

      // Hidden hands — each player can read/write ONLY their own hand.
      match /hands/{playerId} {
        allow read, write: if isAuthenticated() && request.auth.uid == playerId;
      }

      // Stories written on the board — visible to everyone in the game; only the
      // author can create/edit/remove their own.
      match /stories/{storyId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.byUid == request.auth.uid;
        allow update, delete: if isAuthenticated() && resource.data.byUid == request.auth.uid;
      }
    }

    // Side Quest — the Hall of Absurdity, a public feed of completed quests.
    // Posts are created by (anonymous) signed-in users; photos travel inline
    // as a compressed JPEG blob, capped so docs stay well under the 1MB limit.
    match /sidequestPosts/{postId} {
      allow read: if true;

      allow create: if isAuthenticated()
                    && request.resource.data.byUid == request.auth.uid
                    && request.resource.data.story is string
                    && request.resource.data.story.size() <= 2000
                    && request.resource.data.username is string
                    && request.resource.data.username.size() <= 24
                    && request.resource.data.questTitle is string
                    && request.resource.data.questTitle.size() <= 100
                    && (!('image' in request.resource.data)
                        || (request.resource.data.image is bytes
                            && request.resource.data.image.size() <= 400000));

      // Anyone signed in can react, but ONLY the reactions map may change.
      allow update: if isAuthenticated()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['reactions']);

      // The author can take their post down.
      allow delete: if isAuthenticated()
                    && resource.data.byUid == request.auth.uid;
    }

    // Side Quest push tokens — written by the app so Cloud Functions can ping
    // you on a match / chat message. Owner-only; functions read via admin SDK.
    match /sidequestUsers/{uid} {
      allow read, write: if isOwner(uid);
    }

    // Side Quest moderation reports — write-only from clients; reviewed in the
    // Firebase console (and by Cloud Functions / admin tooling later).
    match /sidequestReports/{reportId} {
      allow create: if isAuthenticated()
                    && request.resource.data.byUid == request.auth.uid
                    && request.resource.data.text is string
                    && request.resource.data.text.size() <= 600;
      allow read, update, delete: if false;
    }

    // Side Quest party matchmaking — one doc per hero waiting in a city.
    // A matcher claims waiting heroes by stamping ONLY a partyId onto their
    // queue docs (in the same transaction that creates the party).
    match /sidequestQueue/{uid} {
      allow read: if isAuthenticated();

      allow create: if isOwner(uid)
                    && request.resource.data.username is string
                    && request.resource.data.username.size() <= 24
                    && request.resource.data.cityKey is string
                    && request.resource.data.cityKey.size() <= 60
                    && request.resource.data.cityName is string
                    && request.resource.data.cityName.size() <= 60;

      // Owner may refresh their own doc; anyone signed in may set ONLY the
      // partyId (the claim). A doc already claimed can't be re-claimed.
      allow update: if isOwner(uid)
                    || (isAuthenticated()
                        && !('partyId' in resource.data)
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['partyId']));

      allow delete: if isOwner(uid);
    }

    // Side Quest parties — a matched group + their co-op quest + chat.
    match /sidequestParties/{partyId} {
      function isPartyMember() {
        return isAuthenticated()
            && request.auth.uid in get(/databases/$(database)/documents/sidequestParties/$(partyId)).data.memberIds;
      }

      allow read: if isAuthenticated();

      // Created by a member, small parties only (2–4 heroes).
      allow create: if isAuthenticated()
                    && request.auth.uid in request.resource.data.memberIds
                    && request.resource.data.memberIds.size() >= 2
                    && request.resource.data.memberIds.size() <= 4;

      // Members can update (mark completed); membership can't be rewritten.
      allow update: if isAuthenticated()
                    && request.auth.uid in resource.data.memberIds
                    && request.resource.data.memberIds == resource.data.memberIds;

      allow delete: if false;

      // Party chat — members only, text capped.
      match /messages/{msgId} {
        allow read: if isPartyMember();
        allow create: if isPartyMember()
                      && request.resource.data.byUid == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 500;
        allow update, delete: if false;
      }
    }

    // Group dream journals — membership-scoped collaborative journals.
    // A group is a bounded set of members who share dream entries with each other.
    match /groups/{groupId} {
      // Membership/ownership checks that FETCH the group doc. These are for the
      // SUBCOLLECTION rules below (entries), where the group is a different
      // document than the one being accessed, so get() is required and valid.
      function isGroupMember() {
        return isAuthenticated()
            && request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
      }
      function isGroupOwner() {
        return isAuthenticated()
            && get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid;
      }

      // Read/list the groups you belong to. This MUST use resource.data (not
      // get()) so the membership list query — where('memberIds',
      // 'array-contains', uid) — is allowed: get() on the very document being
      // queried isn't valid for a collection list and fails the whole query.
      allow read: if isAuthenticated() && request.auth.uid in resource.data.memberIds;

      // Any signed-in user can create a group, but only as its own owner and
      // listed among the initial members (prevents creating groups for others).
      allow create: if isAuthenticated()
                    && request.resource.data.ownerId == request.auth.uid
                    && request.auth.uid in request.resource.data.memberIds;

      // Only the owner can change metadata / membership or delete the group.
      // (Join-via-invite can later relax this to a constrained self-add or a
      // Cloud Function; kept owner-only for v1 to stay safe.)
      allow update, delete: if isAuthenticated()
                    && resource.data.ownerId == request.auth.uid;

      // Dream entries — any member reads all entries and posts their own.
      match /entries/{entryId} {
        allow read: if isGroupMember();

        // A member may create only entries authored by themselves.
        allow create: if isGroupMember()
                      && request.resource.data.authorId == request.auth.uid;

        // Only the original author can edit their entry (author cannot be reassigned).
        allow update: if isGroupMember()
                      && resource.data.authorId == request.auth.uid
                      && request.resource.data.authorId == request.auth.uid;

        // The author can delete their own entry; the group owner can remove any
        // entry (moderation).
        allow delete: if isGroupMember()
                      && (resource.data.authorId == request.auth.uid || isGroupOwner());
      }
    }

    // ─── ShouldiMakeThis.com (shouldimakethis.web.app, code in shouldimakethis/) ───
    // Preorder-validation site. The catalog is hardcoded in the app; Firestore
    // holds only interactions. Aggregate counts on simtProducts/{pid} are
    // maintained ONLY by Cloud Functions (functions/simt.js) — clients write
    // just their own per-user docs in the subcollections. pid is a catalog id
    // ("1".."40") or a simtSubmissions doc id (approved submissions collect
    // interactions the same way).
    function isSimtAdmin() {
      return isAuthenticated()
          && request.auth.token.email == 'sageryza@gmail.com'
          && request.auth.token.email_verified == true;
    }

    match /simtProducts/{pid} {
      // Aggregates are public; nothing writes them from the client.
      allow read: if true;
      allow write: if false;

      match /simtVotes/{uid} {
        allow create, update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly(['dir', 'uid', 'pid', 'at'])
                      && request.resource.data.dir in ['up', 'down']
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.pid == pid;
        // Voting the same direction again clears it.
        allow delete: if isOwner(uid);
      }

      match /simtHearts/{uid} {
        allow create, update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly(['uid', 'pid', 'at'])
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.pid == pid;
        allow delete: if isOwner(uid);
      }

      match /simtPreorders/{uid} {
        allow create, update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly(['uid', 'pid', 'variant', 'at'])
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.pid == pid
                      && (request.resource.data.variant == null
                          || (request.resource.data.variant is string
                              && request.resource.data.variant.size() <= 80));
        allow delete: if isOwner(uid);
      }

      match /simtInvestments/{uid} {
        // One doc per user per product; repeat investments accumulate into
        // `amount`. No deletes — this is the demand signal the site exists
        // to collect.
        allow create, update: if isOwner(uid)
                      && request.resource.data.keys().hasOnly(['uid', 'pid', 'amount', 'pay', 'at'])
                      && request.resource.data.uid == request.auth.uid
                      && request.resource.data.pid == pid
                      && request.resource.data.amount is number
                      && request.resource.data.amount > 0
                      && request.resource.data.amount <= 100000
                      && request.resource.data.pay in ['now', 'later'];
        allow delete: if false;
      }
    }

    // Collection-group reads so the app can load "everything I've interacted
    // with" in one query per type (filtered on uid — the equality filter is
    // what makes the rule provable for the query).
    match /{path=**}/simtVotes/{uid} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
    match /{path=**}/simtHearts/{uid} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
    match /{path=**}/simtPreorders/{uid} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
    match /{path=**}/simtInvestments/{uid} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // User-submitted items. Born pending; the public only ever sees approved
    // ones; approve/reject happens on /results (admin = verified owner email).
    match /simtSubmissions/{subId} {
      allow read: if resource.data.status == 'approved'
                  || (isAuthenticated() && resource.data.uid == request.auth.uid)
                  || isSimtAdmin();
      allow create: if isAuthenticated()
                    && request.resource.data.keys().hasOnly(['uid', 'title', 'retail', 'cost', 'goal', 'desc', 'cat', 'img', 'status', 'at'])
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.title is string
                    && request.resource.data.title.size() >= 1
                    && request.resource.data.title.size() <= 100
                    && request.resource.data.desc is string
                    && request.resource.data.desc.size() <= 1000
                    && request.resource.data.cat is string
                    && request.resource.data.cat.size() <= 24
                    && request.resource.data.img is string
                    && request.resource.data.img.size() <= 600
                    && request.resource.data.retail is number
                    && request.resource.data.cost is number
                    && request.resource.data.goal is number;
      allow update, delete: if isSimtAdmin();
    }
  }
}