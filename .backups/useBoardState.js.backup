import { useState, useEffect } from 'react';
import {
  doc,
  onSnapshot,
  setDoc,
  serverTimestamp
} from 'firebase/firestore';
import { db } from '../firebase';

export const useBoardState = (userId) => {
  const [boardState, setBoardState] = useState({
    droppedMemories: [],
    connections: [],
    standalonePins: []
  });
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  useEffect(() => {
    if (!userId) {
      setBoardState({
        droppedMemories: [],
        connections: [],
        standalonePins: []
      });
      setLoading(false);
      return;
    }

    const boardStateRef = doc(db, 'users', userId, 'boardState', 'current');

    const unsubscribe = onSnapshot(
      boardStateRef,
      (snapshot) => {
        if (snapshot.exists()) {
          const data = snapshot.data();
          setBoardState({
            droppedMemories: data.droppedMemories || [],
            connections: data.connections || [],
            standalonePins: data.standalonePins || []
          });
        } else {
          // Initialize with empty state if document doesn't exist
          setBoardState({
            droppedMemories: [],
            connections: [],
            standalonePins: []
          });
        }
        setLoading(false);
        setError(null);
      },
      (error) => {
        console.error('Error fetching board state:', error);
        setError(error.message);
        setLoading(false);
      }
    );

    return () => unsubscribe();
  }, [userId]);

  // Update the board state
  const updateBoardState = async (newState) => {
    if (!userId) return;

    try {
      const boardStateRef = doc(db, 'users', userId, 'boardState', 'current');
      await setDoc(boardStateRef, {
        ...newState,
        updatedAt: serverTimestamp()
      });
    } catch (error) {
      console.error('Error updating board state:', error);
      throw error;
    }
  };

  return {
    boardState,
    loading,
    error,
    updateBoardState
  };
};

export default useBoardState;