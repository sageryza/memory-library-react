/* Constellation star styling */
.constellation-star-svg {
  display: block;
  filter: drop-shadow(0 0 4px rgba(255, 215, 0, 0.6));
  position: relative;
}

.constellation-star .star-fill {
  animation: starPulse 2s ease-in-out infinite;
}

/* Dazzle effect for stars */
@keyframes dazzle {
  0% {
    opacity: 0;
    transform: translateX(-150%) translateY(0) rotate(-45deg) scaleX(0);
  }
  30% {
    opacity: 1;
    transform: translateX(-50%) translateY(0) rotate(-45deg) scaleX(1);
  }
  70% {
    opacity: 1;
    transform: translateX(50%) translateY(0) rotate(-45deg) scaleX(1);
  }
  100% {
    opacity: 0;
    transform: translateX(150%) translateY(0) rotate(-45deg) scaleX(0);
  }
}

.star-dazzle {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 150%;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.9), transparent);
  transform-origin: center;
  animation: dazzle 2.5s ease-in-out infinite;
  pointer-events: none;
  box-shadow: 0 0 4px rgba(255, 255, 255, 0.8);
}

.star-dazzle-large {
  height: 3px;
  width: 180%;
}

/* Remove red circle background when pin becomes a star */
.memory-pin.constellation-star {
  background: transparent;
  border: none;
  width: 20px;
  height: 20px;
  position: absolute;
  top: -3px;
  right: 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  z-index: 200;
}

.memory-pin.constellation-star:hover {
  transform: none;
  box-shadow: none;
}

/* Standalone pins as stars should be bigger */
.standalone-pin.constellation-star {
  width: 30px;
  height: 30px;
  /* Adjust position to center on connection point */
  /* Connection is at pin.x + 10, pin.y + 24 */
  /* Star center (30x30) is at +15, +15 from top-left */
  /* So: top-left = (pin.x - 5, pin.y + 9) */
  margin-left: -5px;
  margin-top: 9px;
}

@keyframes starPulse {
  0%, 100% {
    opacity: 1;
    filter: drop-shadow(0 0 4px rgba(255, 215, 0, 0.8));
  }
  50% {
    opacity: 0.8;
    filter: drop-shadow(0 0 8px rgba(255, 215, 0, 1));
  }
}

