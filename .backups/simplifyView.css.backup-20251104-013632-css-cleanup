/* ===== SIMPLIFY VIEW STYLES ===== */
/* Shared styles for simplified/stacked view across Archive and Conspiracy Board */

/* Hide content and hashtags in simplified view */
.memories-container.simplify-view .memory-content,
.simplify-view .memory-content {
    display: none !important;
}

.memories-container.simplify-view .memory-hashtags,
.simplify-view .memory-hashtags {
    display: none !important;
}

/* Simplified title styling */
.memories-container.simplify-view .memory-title,
.simplify-view .memory-title {
    line-height: 1.1;
    text-align: center;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    font-size: 16px;
    word-wrap: break-word;
    overflow: hidden;
}

/* Override column/masonry layout for simplify view in Archive */
.memories-container.simplify-view {
    display: flex !important;
    flex-wrap: wrap;
    gap: 15px;
    align-content: flex-start;
}

/* Make cards uniform squares in simplify view */
.memories-container.simplify-view .memory-item {
    min-height: 120px;
    max-height: 120px;
    padding: 8px;
    width: 120px;
    height: 120px;
    flex: 0 0 120px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 0;
    overflow: hidden;
}

.memories-container.simplify-view .memory-header {
    margin-bottom: 0;
    width: 100%;
    justify-content: center;
}

/* Simplify view button styles */
.simplify-view-btn {
    background: none;
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 8px 12px;
    cursor: pointer;
    color: #666;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.simplify-view-btn:hover {
    background: #f8f8f8;
    border-color: #800020;
    color: #800020;
}

.simplify-view-btn.active {
    background: #800020;
    color: white;
    border-color: #800020;
}

/* Conspiracy Board specific - stacked view adjustments */
.dropped-memory.stacked-view {
    width: 120px;
    height: 120px;
}

.dropped-memory.stacked-view .memory-card {
    width: 120px;
    height: 120px;
    padding: 8px;
}

.dropped-memory.stacked-view .memory-card-content,
.dropped-memory.stacked-view .memory-card-tags {
    display: none !important;
}

.dropped-memory.stacked-view .memory-card-title {
    line-height: 1.1;
    text-align: center;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    font-size: 16px;
    word-wrap: break-word;
    overflow: hidden;
}

/* Pin positioning adjustment for stacked view */
.dropped-memory.stacked-view .memory-pin {
    top: -17px;
    right: -2px;
}
