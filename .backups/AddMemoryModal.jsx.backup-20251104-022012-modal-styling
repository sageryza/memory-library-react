import { useState, useEffect } from 'react'
import '../shared/MemoryModal.css' // Using shared modal styles to avoid duplication

export default function AddMemoryModal({ isOpen, onClose, onSave, editingMemory = null }) {
  const [memoryUnits, setMemoryUnits] = useState([{
    id: 0,
    content: '',
    title: '',
    hashtags: '',
    additionalContext: '',
    showContext: false,
    showSort: false
  }])

  // Reset form when opening/closing
  useEffect(() => {
    if (isOpen) {
      if (editingMemory) {
        // Editing mode - populate with existing memory data
        setMemoryUnits([{
          id: 0,
          content: editingMemory.content || '',
          title: editingMemory.title || '',
          hashtags: editingMemory.hashtags ? editingMemory.hashtags.join(' ') : '',
          additionalContext: editingMemory.additionalContext || '',
          showContext: false,
          showSort: false
        }])
      } else {
        // New memory mode - reset to empty
        setMemoryUnits([{
          id: 0,
          content: '',
          title: '',
          hashtags: '',
          additionalContext: '',
          showContext: false,
          showSort: false
        }])
      }
    }
  }, [isOpen, editingMemory])

  const updateUnit = (id, field, value) => {
    setMemoryUnits(units => units.map(unit =>
      unit.id === id ? { ...unit, [field]: value } : unit
    ))
  }

  const toggleSection = (id, section) => {
    setMemoryUnits(units => units.map(unit =>
      unit.id === id ? { ...unit, [section]: !unit[section] } : unit
    ))
  }

  const addNewUnit = () => {
    const newId = Math.max(...memoryUnits.map(u => u.id)) + 1
    setMemoryUnits([...memoryUnits, {
      id: newId,
      content: '',
      title: '',
      hashtags: '',
      additionalContext: '',
      showContext: false,
      showSort: false
    }])
  }

  const handleSave = () => {
    // Filter out empty units
    const validUnits = memoryUnits.filter(unit =>
      unit.content.trim() || unit.title.trim() || unit.hashtags.trim()
    )

    if (validUnits.length === 0) {
      alert('Please enter at least one memory')
      return
    }

    // Convert to memories format
    const memories = validUnits.map(unit => ({
      // Don't include ID for new memories - let Firebase generate it
      ...(editingMemory && { id: String(editingMemory.id) }),
      content: String(unit.content.trim()),
      title: String(unit.title.trim()),
      hashtags: unit.hashtags.trim().split(/\s+/).filter(Boolean).map(tag => String(tag)),
      additionalContext: String(unit.additionalContext.trim()),
      timestamp: editingMemory ? editingMemory.timestamp : new Date().toISOString(),
      dateTime: editingMemory ? editingMemory.dateTime : new Date().toLocaleDateString()
    }))

    onSave(memories, !!editingMemory)
    onClose()
  }

  // Handle keyboard shortcuts
  useEffect(() => {
    const handleKeyDown = (e) => {
      if (!isOpen) return

      // ESC to close
      if (e.key === 'Escape') {
        onClose()
      }
      // Ctrl+Enter to save
      else if (e.ctrlKey && e.key === 'Enter') {
        e.preventDefault()
        handleSave()
      }
    }

    window.addEventListener('keydown', handleKeyDown)
    return () => window.removeEventListener('keydown', handleKeyDown)
  }, [isOpen, memoryUnits])

  if (!isOpen) return null

  return (
    <div className="add-memory-popup show" onClick={(e) => e.target === e.currentTarget && onClose()}>
      <div className="add-memory-popup-content">
        <div className="add-memory-header">
          <h3>{editingMemory ? 'Edit Memory' : 'New Memory'}</h3>
          <button className="add-memory-close" onClick={onClose}>&times;</button>
        </div>

        <div id="memoryUnits">
          {memoryUnits.map((unit, index) => (
            <div key={unit.id} className="memory-unit" data-index={index}>
              <textarea
                className="memory-input"
                placeholder="Enter your memory..."
                rows="8"
                value={unit.content}
                onChange={(e) => updateUnit(unit.id, 'content', e.target.value)}
                autoFocus={index === 0}
              />

              <div className="form-toggle-buttons">
                <button
                  type="button"
                  className={`btn-toggle-section context-btn ${unit.showContext ? 'active' : ''}`}
                  onClick={() => toggleSection(unit.id, 'showContext')}
                >
                  Context
                </button>
                <button
                  type="button"
                  className={`btn-toggle-section sort-btn ${unit.showSort ? 'active' : ''}`}
                  onClick={() => toggleSection(unit.id, 'showSort')}
                >
                  Sort
                </button>
                {!editingMemory && (
                  <button
                    type="button"
                    className="btn-add-new add-new-btn"
                    onClick={addNewUnit}
                  >
                    Add New
                  </button>
                )}
              </div>

              {/* Context Section */}
              <div
                className="form-group additional-context-group context-section"
                style={{ display: unit.showContext ? 'block' : 'none' }}
              >
                <div className="form-row">
                  <label>Context:</label>
                  <textarea
                    className="additional-context"
                    rows="4"
                    placeholder="why do you think you remembered this for so long?"
                    value={unit.additionalContext}
                    onChange={(e) => updateUnit(unit.id, 'additionalContext', e.target.value)}
                  />
                </div>
              </div>

              {/* Sort Section (Title & Hashtags) */}
              <div
                className="sort-section"
                style={{ display: unit.showSort ? 'block' : 'none' }}
              >
                <div className="form-group">
                  <div className="form-row">
                    <label>Title:</label>
                    <input
                      type="text"
                      className="memory-title-input"
                      value={unit.title}
                      onChange={(e) => updateUnit(unit.id, 'title', e.target.value)}
                    />
                  </div>
                </div>
                <div className="form-group">
                  <div className="form-row">
                    <label>Hashtags:</label>
                    <input
                      type="text"
                      className="memory-hashtags-input"
                      placeholder="#example #memory"
                      value={unit.hashtags}
                      onChange={(e) => updateUnit(unit.id, 'hashtags', e.target.value)}
                    />
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div className="add-memory-actions">
          <button className="btn-trash" onClick={() => {}} title="Clear All">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M6.5 1h3a.5.5 0 0 1 .5.5v1H6v-1a.5.5 0 0 1 .5-.5ZM11 2.5v-1A1.5 1.5 0 0 0 9.5 0h-3A1.5 1.5 0 0 0 5 1.5v1H2.506a.58.58 0 0 0-.01 0H1.5a.5.5 0 0 0 0 1h.538l.853 10.66A2 2 0 0 0 4.885 16h6.23a2 2 0 0 0 1.994-1.84L14.962 3.5H15.5a.5.5 0 0 0 0-1h-1.004a.58.58 0 0 0-.01 0H11Zm1.958 1-.846 10.58a1 1 0 0 1-.997.92h-6.23a1 1 0 0 1-.997-.92L3.042 3.5h9.916Zm-7.487 1a.5.5 0 0 1 .528.47l.5 8.5a.5.5 0 0 1-.998.06L5 5.03a.5.5 0 0 1 .47-.53Zm5.058 0a.5.5 0 0 1 .47.53l-.5 8.5a.5.5 0 1 1-.998-.06l.5-8.5a.5.5 0 0 1 .528-.47ZM8 4.5a.5.5 0 0 1 .5.5v8.5a.5.5 0 0 1-1 0V5a.5.5 0 0 1 .5-.5Z"/>
            </svg>
          </button>
          <button className="btn-primary" onClick={handleSave}>
            Save
          </button>
        </div>
      </div>
    </div>
  )
}