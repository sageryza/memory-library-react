import { useState, useEffect } from 'react'

export default function VennDiagramModal({ connection, memories, isOpen, onClose, onSave }) {
  const [insight, setInsight] = useState('')

  useEffect(() => {
    if (connection && isOpen) {
      // Load existing insight from connection object
      setInsight(connection.insight || '')
    }
  }, [connection, isOpen])

  if (!isOpen || !connection) return null

  const fromMemory = memories.find(m => m.id === connection.from)
  const toMemory = memories.find(m => m.id === connection.to)

  const handleSave = () => {
    // Pass insight to parent to save in Firebase
    onSave(connection, insight.trim())
    onClose()
  }

  const handleClear = () => {
    setInsight('')
  }

  return (
    <div className="modal-overlay" onClick={onClose}>
      <div className="modal-content venn-diagram-modal" onClick={e => e.stopPropagation()}>
        <button className="modal-close" onClick={onClose}>×</button>

        <h2>Connection Analysis</h2>

        <div className="venn-diagram">
          <svg width="400" height="250" viewBox="0 0 400 250">
            {/* Left circle */}
            <circle
              cx="150"
              cy="125"
              r="80"
              fill="#800020"
              fillOpacity="0.3"
              stroke="#800020"
              strokeWidth="2"
            />
            {/* Right circle */}
            <circle
              cx="250"
              cy="125"
              r="80"
              fill="#800020"
              fillOpacity="0.3"
              stroke="#800020"
              strokeWidth="2"
            />
            {/* Labels */}
            <text x="150" y="125" textAnchor="middle" fill="#800020" fontSize="14" fontWeight="bold">
              {fromMemory?.title?.substring(0, 15) || 'Memory 1'}
            </text>
            <text x="250" y="125" textAnchor="middle" fill="#800020" fontSize="14" fontWeight="bold">
              {toMemory?.title?.substring(0, 15) || 'Memory 2'}
            </text>
          </svg>
        </div>

        <div className="venn-titles">
          <div className="venn-title">{fromMemory?.title || 'Untitled'}</div>
          <div className="venn-connector">↔</div>
          <div className="venn-title">{toMemory?.title || 'Untitled'}</div>
        </div>

        <textarea
          className="insight-textarea"
          placeholder="What's the connection between these memories?"
          value={insight}
          onChange={(e) => setInsight(e.target.value)}
          rows="5"
        />

        <div className="modal-buttons">
          <button className="btn btn-clear" onClick={handleClear}>Clear</button>
          <button className="btn btn-save" onClick={handleSave}>Save Insight</button>
        </div>
      </div>
    </div>
  )
}